# Copy to `.env` and fill in. Never commit `.env`.

# --- Public API (server + mobile; use same base URL, no trailing slash) ---
API_PUBLIC_URL=
APP_DOMAIN=
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_DOMAIN=

# Google OAuth (rotate client secret if it was ever committed to Git)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL (optional if API_PUBLIC_URL is set)
GOOGLE_OAUTH_REDIRECT_URI=

# Web client ID (Expo / Cloud Run env injection)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# CORS: comma-separated extra allowed origins (optional)
CORS_ALLOWED_ORIGINS=

# --- Firebase (client / Expo public) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# --- Bunny.net (optional) ---
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_REGION=uk
BUNNY_CDN_URL=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=

# --- Database & AI (server) ---
DATABASE_URL=
NEON_DATABASE_URL=
SUPABASE_DATABASE_URL=
OPENAI_API_KEY=
RESEND_API_KEY=

# --- Slack (optional) ---
SLACK_WEBHOOK=

# --- Deploy scripts (optional; never commit real values) ---
VERCEL_TOKEN=
FIREBASE_DEPLOY_TOKEN=
FIREBASE_HOSTING_PROJECT=arunmobi-app
VERCEL_PROJECT_NAME=mobi-repair
