# Copy to `.env` and fill in. Never commit `.env`.

# --- Public API (server + mobile; same base URL; https:// recommended) ---
API_PUBLIC_URL=
APP_DOMAIN=
# Backend (Cloud Run) — used for all /api/* calls. Must be https://your-service.run.app (NOT *.web.app).
EXPO_PUBLIC_API_URL=
# Public web app URL (Firebase) — for links/sharing only; never used as API base in getApiUrl().
# Example: https://arunmobi-app.web.app (do not set this to your Cloud Run URL).
EXPO_PUBLIC_DOMAIN=
# Optional aliases (read at build time in app.config.js → extra.publicApiUrl; Expo client inlines EXPO_PUBLIC_* only)
VITE_API_URL=
REACT_APP_API_URL=
# EAS Build: set EXPO_PUBLIC_API_URL in eas.json or EAS secrets. Production web: see committed .env.production.
# .env.local overrides .env.production — delete bad EXPO_PUBLIC_* there (e.g. api.example.com) or the hosted site will call the wrong host.

# Google OAuth (rotate client secret if it was ever committed to Git)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL (optional if API_PUBLIC_URL is set)
GOOGLE_OAUTH_REDIRECT_URI=

# Web client ID (Expo / Cloud Run env injection)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Android Maps SDK (EAS secret EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY or EXPO_PUBLIC_GOOGLE_MAPS_API_KEY)
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=
# Web (Expo web / Metro web): Maps JavaScript API — REQUIRED for maps on web. Use a browser key with HTTP referrer restrictions (not the Android SDK key).
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=
# Optional: same key as backup for native code paths that still read this name (not used by web loader).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# CORS: comma-separated extra allowed origins (optional)
CORS_ALLOWED_ORIGINS=

# --- Firebase (client / Expo public) ---
# Create `.env` in this folder (copy from this file), paste the Web app `firebaseConfig` from:
#   Firebase Console → Project settings → General → Your apps → Web app
# Names must match exactly (EXPO_PUBLIC_ prefix required for client). After any change, restart Metro with a clean cache:
#   npm run start:clear   (same as: npx expo start -c)
# Do not commit `.env` — it is listed in `.gitignore`.
# Values must match Firebase Console → Project settings → Your apps (Web).
# This codebase expects EXPO_PUBLIC_FIREBASE_PROJECT_ID=arunmobi-app (Firebase Hosting project; not mobi-backend).
# If the browser shows getProjectConfig → 400, open DevTools → Network → Response body:
#   API_KEY_INVALID → wrong key or not the Web app key from Firebase.
#   IP_REFERER_BLOCKED / API_KEY_HTTP_REFERRER_BLOCKED → Google Cloud → APIs & Services →
#   Credentials → your key → Website restrictions: add BOTH:
#     https://arunmobi-app.web.app/*
#     https://arunmobi-app.firebaseapp.com/*
#   (add localhost for dev). Under API restrictions, allow "Identity Toolkit API" (or Firebase services).
#   Also enable "Identity Toolkit API" in API Library for this GCP project.
#   CONFIGURATION_NOT_FOUND → the browser key is not the Firebase *Web app* key for this project, or
#   EXPO_PUBLIC_FIREBASE_* are mixed from two projects (e.g. apiKey from A, projectId from B), or
#   Firebase Console → Build → Authentication was never opened / no sign-in method added for that project.
#   Fix: copy the full Web app config from Project settings for project arunmobi-app (same as hosting),
#   rebuild web (expo export), redeploy hosting. Cloud Run project (mobi-backend-*) is separate — do not paste its keys here.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# Default bucket from Console — often arunmobi-app.appspot.com or arunmobi-app.firebasestorage.app (same project).
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Optional (Analytics on web): same as Firebase Console Web app snippet
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- OneSignal (push) ---
# Client (EAS / .env): App ID from OneSignal dashboard. Server: same ONESIGNAL_APP_ID + ONESIGNAL_REST_API_KEY.
EXPO_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# Optional: ONESIGNAL_ANDROID_CHANNEL_ID= (Dashboard Android channel UUID), ONESIGNAL_ANDROID_SOUND=default, ONESIGNAL_IOS_SOUND=default
# DB: `npm run db:push` creates `broadcast_push_logs` for admin broadcast history.

# --- Bunny.net (optional) ---
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_REGION=uk
BUNNY_CDN_URL=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=

# --- Database & AI (server) ---
DATABASE_URL=
NEON_DATABASE_URL=
SUPABASE_DATABASE_URL=
OPENAI_API_KEY=
RESEND_API_KEY=

# --- Slack (optional) ---
SLACK_WEBHOOK=

# --- Deploy scripts (optional; never commit real values) ---
VERCEL_TOKEN=
FIREBASE_DEPLOY_TOKEN=
FIREBASE_HOSTING_PROJECT=arunmobi-app
VERCEL_PROJECT_NAME=mobi-repair

# --- GitHub Actions (repository Secrets, not .env) ---
# GCP_SA_KEY = entire service account JSON key for Cloud Build + Cloud Run deploy.
